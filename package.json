{
  "name": "d4dad",
  "version": "2.1.0",
  "private": true,
  "engines": {
    "node": ">=22.12 <23"
  },
  "dependencies": {
    "@floating-ui/react": "^0.27.19",
    "@headlessui/react": "^2.2.10",
    "@szhsin/react-accordion": "^1.2.4",
    "classnames": "^2.5.1",
    "firebase": "^12.15.0",
    "fuse.js": "^7.0.0",
    "normalize.css": "^8.0.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-lazy-load-image-component": "^1.6.2",
    "react-router-dom": "^6.23.1",
    "usehooks-ts": "^3.1.0",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "analyze": "source-map-explorer 'build/assets/*.js'",
    "build": "npm run typecheck && vite build",
    "check": "npm run lint && npm test && npm run build",
    "e2e": "start-server-and-test start:e2e http://127.0.0.1:5173 e2e:run",
    "e2e:open": "cypress open",
    "e2e:run": "cypress run",
    "export:catalog-seed": "node scripts/export-catalog-seed.cjs",
    "lint": "oxlint src --tsconfig tsconfig.json --deny correctness --deny suspicious --allow react-in-jsx-scope",
    "preview": "vite preview",
    "set:editor-role": "node scripts/set-editor-role.cjs",
    "start": "vite",
    "start:e2e": "vite --host 127.0.0.1 --port 5173 --strictPort",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "upload:catalog-seed": "node scripts/upload-catalog-seed.cjs"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "prettier --write"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/dom": "^10.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.20.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/react-lazy-load-image-component": "^1.6.4",
    "@vitejs/plugin-react": "^6.0.3",
    "cypress": "^15.18.0",
    "husky": "^9.0.11",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.2.7",
    "oxlint": "^0.16.7",
    "prettier": "^3.3.2",
    "source-map-explorer": "^2.5.3",
    "start-server-and-test": "^3.0.11",
    "typescript": "^4.9.5",
    "vite": "^8.1.0",
    "vitest": "^4.1.9"
  }
}
