{
  "name": "d4dad",
  "version": "2.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "dependencies": {
    "@floating-ui/react": "^0.26.20",
    "@headlessui/react": "^2.2.10",
    "@szhsin/react-accordion": "^1.2.4",
    "classnames": "^2.5.1",
    "firebase": "^10.7.2",
    "fuse.js": "^7.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-lazy-load-image-component": "^1.6.2",
    "react-router-dom": "^6.23.1",
    "usehooks-ts": "^3.1.0",
    "web-vitals": "^2.1.4"
  },
  "scripts": {
    "analyze": "source-map-explorer 'build/assets/*.js'",
    "start": "vite",
    "build": "npm run typecheck && vite build",
    "export:catalog-seed": "node scripts/export-catalog-seed.cjs",
    "preview": "vite preview",
    "set:editor-role": "node scripts/set-editor-role.cjs",
    "upload:catalog-seed": "node scripts/upload-catalog-seed.cjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "src/**/*.{js,jsx,ts,tsx,json,css,scss,md}": [
      "prettier --write"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],  
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "@types/node": "^22.10.10",
    "@types/react": "^18.2.42",
    "@types/react-dom": "^18.2.17",
    "@types/react-lazy-load-image-component": "^1.6.4",
    "@vitejs/plugin-react": "^4.3.4",
    "cypress": "^13.15.2",
    "husky": "^9.0.11",
    "jsdom": "^25.0.1",
    "lint-staged": "^15.2.7",
    "prettier": "^3.3.2",
    "source-map-explorer": "^2.5.3",
    "typescript": "^4.9.5",
    "vite": "^5.4.19",
    "vitest": "^2.1.9"
  }
}
