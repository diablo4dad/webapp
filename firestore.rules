rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function hasEditorRole() {
      return request.auth != null && (
        request.auth.token.role == "EDITOR" ||
        request.auth.token.editor == true ||
        (request.auth.token.roles is list && "EDITOR" in request.auth.token.roles)
      );
    }

    match /catalogs/{catalogId} {
      allow read: if true;
      allow write: if hasEditorRole();

      match /{document=**} {
        allow read: if true;
        allow write: if hasEditorRole();
      }
    }

    match /collections/{userId} {
      allow read, write: if userId == request.auth.uid;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
